{
  "library_version": "2026-04-24.v1",
  "default_intent": "general_exposure",
  "intents": [
    {
      "intent": "negative_news_exposure",
      "description": "Identify potential negative-news exposure, including Panama Papers nexus signals.",
      "priority": 125,
      "patterns": [
        "negative news",
        "adverse media",
        "panama papers",
        "media exposure",
        "reputation risk"
      ],
      "synonyms": [
        "offshore leaks",
        "panama nexus",
        "public allegations"
      ],
      "top_seed_count": 4,
      "assumptions": [
        "Panama Papers relationship links are treated as potential negative-news nexus indicators.",
        "Negative-news evidence in this mode is currently proxy-based from graph and Panama reference relationships."
      ],
      "limitations": [
        "This mode does not yet include external news article retrieval; it uses internal graph-linked proxies.",
        "Panama nexus indicates investigative relevance, not a final adverse determination."
      ],
      "query_plan_template": {
        "steps": [
          {
            "step": 1,
            "name": "seed_search",
            "query_type": "lexical_entity_seed_search",
            "endpoint": "/api/graph/exposure-seed-search",
            "params": {
              "q": "{question}",
              "limit": "{seed_limit}"
            }
          },
          {
            "step": 2,
            "name": "graph_expansion",
            "query_type": "relationship_subgraph_retrieval",
            "endpoint": "/api/graph/exposure",
            "params": {
              "hops": "{hops}",
              "max_nodes": "{max_nodes}",
              "max_edges": "{max_edges}",
              "include_surrogates": "{include_surrogates}",
              "include_ofac_matches": "{include_ofac_matches}",
              "include_txn_flow": "{include_txn_flow}"
            },
            "notes": "Executed for top matched seeds only."
          },
          {
            "step": 3,
            "name": "transaction_details",
            "query_type": "cash_fact_transaction_retrieval",
            "endpoint": "/api/graph/exposure/transactions",
            "params": {
              "hops": "{hops}",
              "limit": "200",
              "outside_country_code_2": "US",
              "direction": "outbound",
              "aml_classification_contains": "",
              "mechanism_contains": "wire"
            },
            "notes": "Run for top seeds to gather detail rows from dh_fact_cash."
          },
          {
            "step": 4,
            "name": "grounded_summary",
            "query_type": "evidence_constrained_synthesis",
            "notes": "Summary must reference retrieved evidence only."
          }
        ]
      }
    },
